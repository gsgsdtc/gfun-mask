# 服务
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# 阿里云 DashScope API Key（STT / LLM / TTS 共用同一个 Key）
# 控制台获取：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-aa47f65213a246e3a137ed2d6ed86082

# STT：阿里云 Paraformer 语音识别
STT_MODEL=paraformer-realtime-v2  # 实时识别模型，用 Recognition.call() 批量识别 < 1s

# LLM：通义千问
LLM_MODEL=qwen-turbo             # qwen-turbo（快速低成本） | qwen-plus | qwen-max
LLM_SYSTEM_PROMPT=你是一个简洁友好的语音助手，请用中文回答，每次回复不超过50字。

# TTS：阿里云 CosyVoice 语音合成
TTS_MODEL=cosyvoice-v1
TTS_VOICE=longxiaochun            # longxiaochun（女声） | longshuo（男声） | longyue
